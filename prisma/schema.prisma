// Schema - Sistema de Registro de Problemas Universitarios
// Proyecto: RePoUNI
// Base de datos: PostgreSQL (Railway)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Problema {
  id            String   @id @default(cuid())
  titulo        String
  descripcion   String
  categoria     String   // infraestructura | social | estudiantil | academico | seguridad | otros
  ubicacion     String?
  codigoAlumno  String?
  severidad     Int      @default(5)
  estado        String   @default("abierto") // abierto | en_progreso | resuelto
  prioridad     Float    @default(0)
  votos         Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  valoraciones  Valoracion[]

  @@index([categoria])
  @@index([prioridad])
  @@index([estado])
}

model Valoracion {
  id           String   @id @default(cuid())
  problemaId   String
  puntaje      Int
  comentario   String?
  sugerencia   String?
  createdAt    DateTime @default(now())

  problema     Problema @relation(fields: [problemaId], references: [id], onDelete: Cascade)

  @@index([problemaId])
}

model Equipo {
  id        String   @id @default(cuid())
  nombre    String
  rol       String
  orden     Int      @default(0)
}

model CalificacionPagina {
  id           String   @id @default(cuid())
  puntaje      Int      // 1-10
  comentario   String?
  codigoAlumno String?  // opcional - anónimo si es null
  createdAt    DateTime @default(now())
}
