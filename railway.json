{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommands": [
      "npm install",
      "npx prisma generate",
      "npx prisma migrate deploy",
      "npm run build"
    ]
  },
  "deploy": {
    "startCommand": "npx prisma db seed && npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
