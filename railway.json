{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommands": [
      "npm install",
      "npx prisma generate",
      "npm run build"
    ]
  },
  "deploy": {
    "startCommand": "npx prisma migrate deploy && npx prisma db seed || true; node .next/standalone/server.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "environment": {
    "NIXPACKS_NODE_VERSION": "20",
    "NEXT_SHARP_PATH": "/app/node_modules/sharp"
  }
}
